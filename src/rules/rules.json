{
  "rules": [
    {
      "rule_id": "R001",
      "name": "After Hours Restricted Access",
      "condition": "(hour < 8 or hour > 18) and resource_sensitivity == 'high'",
      "severity": "high",
      "actions": ["alert"]
    },

    {
      "rule_id": "R002",
      "name": "Bulk Export",
      "condition": "action == 'export_data' and resource == 'PROD_DB'",
      "severity": "high",
      "actions": ["alert"]
    }
  ]
}